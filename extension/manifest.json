{
  "manifest_version": 3,
  "name": "AiOS Assistant Capture",
  "description": "Send pages, selected text, and wellbeing signals to the local AiOS Assistant.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AiOS Assistant"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
